{
  "name": "svelte-tic-tac-toe-server",
  "version": "1.0.0",
  "description": "Game server for Tic-Tac-Toe with Skills",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "simulate": "tsx src/simulation/run.ts",
    "learn": "tsx src/simulation/learn.ts",
    "play": "tsx src/simulation/play.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "firebase-admin": "^12.1.0",
    "glicko2-lite": "*",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
